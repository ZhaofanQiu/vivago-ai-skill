  "base_url": "https://vivago.ai/api/gw",
  "categories": {
    "text_to_image": {
      "name": "文生图",
      "name_en": "Text to Image",
      "status": "active",
      "default_port": "kling-image",
      "description": "从文本描述生成图像",
      "ports": {
        "kling-image": {
          "name": "Kling Image",
          "status": "tested",
          "endpoint": "/v3/image/image_gen_kling/async",
          "result_endpoint": "/v3/image/txt2img/async/results",
          "version": "kling-image-o1",
          "supported_ratios": ["1:1", "4:3", "3:4", "16:9", "9:16"],
          "max_batch_size": 4,
          "tested": true,
          "notes": "已测试通过，推荐使用"
        },
        "hidream-txt2img": {
          "name": "HiDream Txt2Img",
          "status": "tested",
          "endpoint": "/v3/image/txt2img/async",
          "result_endpoint": "/v3/image/txt2img/async/results",
          "version": "v3L",
          "supported_ratios": ["1:1", "4:3", "3:4", "16:9", "9:16"],
          "max_batch_size": 4,
          "tested": true,
          "notes": "已测试，可用"
        }
      }
    },
    "image_to_video": {
      "name": "图生视频",
      "name_en": "Image to Video",
      "status": "testing",
      "default_port": "v3Pro",
      "description": "从静态图像生成视频",
      "warning": "生成时间较长(2-3分钟)，请谨慎调用",
      "ports": {
        "v3Pro": {
          "name": "V3 Pro",
          "status": "testing",
          "endpoint": "/v3/video/video_diffusion_img2vid/async",
          "result_endpoint": "/v3/video/video_diffusion/async/results",
          "version": "v3Pro",
          "supported_ratios": ["keep", "1:1", "4:3", "3:4", "16:9", "9:16"],
          "max_batch_size": 1,
          "supported_durations": [5, 10],
          "tested": false,
          "notes": "高质量，生成较慢，调试中"
        },
        "v3L": {
          "name": "V3 Lite",
          "status": "untested",
          "endpoint": "/v3/video/video_diffusion_img2vid/async",
          "result_endpoint": "/v3/video/video_diffusion/async/results",
          "version": "v3L",
          "supported_ratios": ["keep", "1:1", "4:3", "3:4", "16:9", "9:16"],
          "max_batch_size": 1,
          "supported_durations": [5, 10],
          "tested": false,
          "notes": "快速版本，待测试"
        },
        "kling-video": {
          "name": "Kling Video",
          "status": "untested",
          "endpoint": "/v3/video/video_diffusion_img2vid/async",
          "result_endpoint": "/v3/video/video_diffusion/async/results",
          "version": "kling-video-o1",
          "supported_ratios": ["keep", "1:1", "4:3", "3:4", "16:9", "9:16"],
          "max_batch_size": 1,
          "supported_durations": [5, 10],
          "tested": false,
          "notes": "Kling视频模型，待测试"
        }
      }
    },
