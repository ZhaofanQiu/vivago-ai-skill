# Vivago AI Skill Environment Variables
# Copy this file to .env and fill in your credentials

# Required: Vivago API Token
HIDREAM_TOKEN=your_hidream_token_here

# Required for image upload: Storage credentials
STORAGE_AK=your_storage_access_key
STORAGE_SK=your_storage_secret_key

# Optional: Test configuration
TEST_IMAGE_UUID=
TEST_MAX_ATTEMPTS=60
TEST_POLL_INTERVAL=3
